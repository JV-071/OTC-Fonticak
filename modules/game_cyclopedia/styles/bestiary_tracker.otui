BestiaryTrackerEntry < Panel
  height: 36
  margin-top: 3

  UICreature
    id: creature
    size: 20 20
    anchors.left: parent.left
    anchors.top: parent.top
    margin-left: 4
    margin-top: 1

  Label
    id: creatureName
    font: verdana-11px-antialised
    color: #dfdfdf
    anchors.left: creature.right
    anchors.verticalCenter: creature.verticalCenter
    margin-left: 4
    width: 120
    text-auto-resize: true

  Panel
    id: progressBg
    height: 12
    background-color: #222222
    border: 1 black
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.top: creature.bottom
    margin-top: 2
    @onGeometryChange: |
      local w = self:getWidth()
      local l1 = self:getParent():getChildById('line1')
      local l2 = self:getParent():getChildById('line2')
      if l1 and l2 then
        l1:setMarginLeft(math.floor(w * 0.33))
        l2:setMarginLeft(math.floor(w * 0.66))
      end

  UIProgressBar
    id: progressBar
    height: 10
    background-color: #e09b00
    anchors.fill: progressBg
    margin: 1
    font: verdana-11px-antialised
    color: white
    text-align: center

  UIWidget
    id: line1
    width: 1
    background-color: #111111
    anchors.left: progressBg.left
    anchors.top: progressBg.top
    anchors.bottom: progressBg.bottom
    phantom: true

  UIWidget
    id: line2
    width: 1
    background-color: #111111
    anchors.left: progressBg.left
    anchors.top: progressBg.top
    anchors.bottom: progressBg.bottom
    phantom: true

BestiaryTrackerMini < MiniWindow
  id: bestiaryTrackerWindow
  height: 150
  @onOpen: modules.game_cyclopedia.onBestiaryTrackerOpen()
  @onClose: modules.game_cyclopedia.onBestiaryTrackerClose()
  &save: true

  UIWidget
    id: miniwindowIcon
    anchors.top: miniwindowHeader.top
    anchors.left: miniwindowHeader.left
    margin-top: 2
    margin-left: 4
    size: 12 12
    image-source: /images/icons/icon-bestiarytracker-widget
    image-smooth: false

  Label
    id: miniwindowTitle
    anchors.top: miniwindowHeader.top
    anchors.left: miniwindowHeader.left
    anchors.right: miniwindowHeader.right
    margin-top: 2
    margin-left: 20
    margin-right: 85
    font: verdana-11px-monochrome
    height: 13
    !text: tr('Bestiary Tracker')
    color: #9d9d9dff

  MiniWindowContents
    id: contentsPanel
    padding-left: 5
    padding-right: 5
    padding-top: 5
    layout: verticalBox
