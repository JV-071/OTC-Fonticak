BestiaryCategory < UIWidget
  font: verdana-11px-antialised
  opacity: 1
  color: #909090
  text-offset: 0 1
  text-align: top
  margin-top: 2
  margin-left: 6
  image-source: /images/game/bestiary/window
  image-border: 4 
  image-border-top: 4

  UIWidget
    id: bestiaryContainer
    size: 64 64
    padding: 1
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 20
    margin-left: 0
    image-source: /images/modern_ui/panel_built
    font: verdana-11px-rounded
    border-color: white
    color: white

    $pressed:
      margin-top: 21
      margin-left: 1

    UICreature
      id: creature
      size: 48 48
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 0
      margin-left: 0

      $pressed:
        margin-top: 1
        margin-left: 1

    UIWidget
      id: hideCreature
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      image-source: /images/game/bestiary/lockedCreature

  Label
    id: creatureProgress
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 88
    color: #c0c0c0

  UIWidget
    id: creatureProgressCheck
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    image-source: /images/game/bestiary/creatureCheck
    margin-top: 88

  Label
    id: monsterId

BestiaryCategoryList < UIWidget
  font: verdana-11px-antialised
  opacity: 1
  color: #909090
  text-offset: 0 1
  text-align: top
  margin-top: 2
  margin-left: 6
  image-source: /images/game/bestiary/window
  image-border: 4 
  image-border-top: 4

  UIWidget
    id: bestiaryContainer
    size: 64 64
    padding: 1
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 20
    margin-left: 0
    image-source: /images/modern_ui/panel_built
    font: verdana-11px-rounded
    border-color: white
    color: white

    $pressed:
      border-color: black
      color: black
      margin-top: 21
      margin-left: 1

    UIWidget
      id: bestiaryImage
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 0
      margin-left: 0

      $pressed:
        margin-top: 1
        margin-left: 1

  Label
    id: totalAmount
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: 85
    color: #c0c0c0

  Label
    id: knownAmount
    anchors.top: prev.bottom
    anchors.horizontalCenter: parent.horizontalCenter
    color: #c0c0c0

  Label
    id: categoryId

UIWidget
  size: 668 452
  visible: false
  margin-left: 0

  UIWidget
    id: bestiaryContainer
    size: 668 390
    opacity: 1
    image-source: /images/modern_ui/black_border
    text-align: top
    image-border: 6
    image-border-top: 15
    anchors.top: parent.top
    anchors.left: parent.left

    UIScrollArea
      id: bestiaryCSelecter
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 1
      margin-bottom: 1
      margin-left: 1
      margin-right: 1
      padding: 1
      auto-focus: none
      layout:
        type: grid
        cell-size: 126 119
        flow: true
        auto-spacing: true

  Button
    id: closeButton
    size: 43 20
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    !text: tr('Close')
    font: cipsoftFont
    @onClick: modules.game_cyclopedia.toggle()

  HorizontalSeparator
    id: horizontalSeparator
    anchors.bottom: closeButton.top
    anchors.left: parent.left
    anchors.right: parent.right
    margin-bottom: 12

  UIWidget
    id: blackBG01
    image-source: /images/modern_ui/image1015925
    image-border: 1
    size: 104 20
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 1

    UIWidget
      id: goldIcon
      image-source: /images/modern_ui/gold
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-bottom: 5
      margin-right: 3

    Label
      id: goldPoints
      text-align: right
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-bottom: 2
      margin-right: 5

  UIWidget
    id: blackBG02
    image-source: /images/modern_ui/image1015925
    image-border: 1
    size: 104 20
    anchors.bottom: parent.bottom
    anchors.left: prev.right
    margin-left: 6
    margin-bottom: 1

    UIWidget
      id: charmIcon
      image-source: /images/modern_ui/charm_big
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-bottom: 3
      margin-right: 3

    Label
      id: charmPoints
      text-align: right
      anchors.bottom: parent.bottom
      anchors.right: prev.left
      margin-bottom: 2
      margin-right: 2
      width: 80

  Button
    id: bestiaryTracker
    size: 86 20
    text: Bestiary Tracker
    font: cipsoftFont
    anchors.bottom: parent.bottom
    anchors.left: prev.right
    margin-left: 6
    margin-bottom: 1

  Button
    id: searchButton
    size: 43 20
    text: Search
    font: cipsoftFont
    anchors.bottom: horizontalSeparator.bottom
    anchors.right: horizontalSeparator.right
    margin-bottom: 7

  TextEdit
    id: searchInput
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.right: prev.left
    margin-right: 5
    size: 150 16

  UIButton
    id: backCategoryButton
    size: 20 20
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.left: parent.left
    margin-left: 235
    image-source: /game_cyclopedia/images/ui/return-button
    image-clip: 0 20 20 20
    padding: 1
    $hover !disabled:
      image-clip: 0 20 20 20
    $pressed:
      image-clip: 0 40 20 20
    $disabled:
      image-clip: 0 0 20 20

  UIButton
    id: backPageButton
    size: 20 20
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.left: backCategoryButton.right
    margin-left: 10
    image-source: /images/ui/arrow-left-button
    image-clip: 0 20 20 20
    padding: 1
    $hover !disabled:
      image-clip: 0 20 20 20
    $pressed:
      image-clip: 0 40 20 20
    $disabled:
      image-clip: 0 0 20 20

  Label
    id: pageCountLabel
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.left: backPageButton.right
    margin-left: 10
    !text: tr('1 / 1')
    font: Verdana-9px
    color: #dfdfdf
    text-auto-resize: true

  UIButton
    id: nextPageButton
    size: 20 20
    anchors.verticalCenter: searchButton.verticalCenter
    anchors.left: pageCountLabel.right
    margin-left: 10
    image-source: /images/ui/arrow-right-button
    image-clip: 0 20 20 20
    padding: 1
    $hover !disabled:
      image-clip: 0 20 20 20
    $pressed:
      image-clip: 0 40 20 20
    $disabled:
      image-clip: 0 0 20 20
