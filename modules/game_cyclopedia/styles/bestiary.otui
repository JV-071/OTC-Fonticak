BestiaryCharmSlot < UIWidget
  size: 37 37
  padding: 1
  image-source: /images/ui/item/none
  border-color: #161616
  border-width: 1

  UIWidget
    id: charmRune
    anchors.fill: parent
    margin: 1
    phantom: true
    visible: false

BestiaryMonster < UIWidget
  id: bestiaryMonster
  anchors.top: parent.top
  anchors.left: parent.left
  font: verdana-11px-antialised
  size: 668 390
  color: #909090
  text-offset: 0 6
  text-align: top
  image-source: /images/modern_ui/window
  image-border: 6
  image-border-top: 27
  border-color: #000000
  border-width-top: 1
  border-width-left: 1
  border-width-bottom: 1
  border-width-right: 1

  UICreature
    id: bestiaryCreature
    size: 96 96
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 40
    margin-left: 25

  CheckBox
    id: trackKills
    !text: tr('Track kills')
    font: verdana-11px-rounded-lowspace
    anchors.top: bestiaryCreature.bottom
    anchors.left: bestiaryCreature.left
    margin-top: 15
    width: 150
    height: 16
    text-offset: 15 -2

  BestiaryCharmSlot
    id: charmSlot1
    anchors.top: charmAmountIcon.bottom
    anchors.left: charmAmountIcon.left
    margin-top: 14

  BestiaryCharmSlot
    id: charmSlot2
    anchors.top: charmSlot1.top
    anchors.left: charmSlot1.right
    margin-left: 4

  Button
    id: assignCharmButton
    size: 86 20
    anchors.verticalCenter: charmSlot1.verticalCenter
    anchors.left: charmSlot2.right
    margin-left: 8
    !text: tr('Assign Charm')
    font: cipsoftFont

  Label
    anchors.bottom: progressBarImage.top
    anchors.horizontalCenter: progressBarImage.horizontalCenter
    margin-bottom: 3
    text: Total Kills
    font: verdana-11px-rounded

  UIWidget
    id: progressBarImage
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    image-source: /images/game/bestiary/bestiaryContainer
    margin-top: 39
    margin-right: 96

  UIProgressBar
    id: progressBar
    anchors.top: progressBarImage.top
    anchors.bottom: progressBarImage.bottom
    anchors.left: progressBarImage.left
    anchors.right: progressBarImage.right
    background-color: #1b7400
    border: 1 black
    height: 5
    phantom: false

  UIWidget
    id: totalKillsLabel
    anchors.verticalCenter: progressBarImage.verticalCenter
    anchors.horizontalCenter: progressBarImage.horizontalCenter
    image-source: /images/game/bestiary/bestiaryContainerBorder
    text: 1

  UIWidget
    id: starsContainer
    size: 60 10
    anchors.top: progressBarImage.bottom
    anchors.left: progressBarImage.left
    margin-top: 9

    BestiaryStars
      id: stars1

    BestiaryStars
      id: stars2
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars3
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars4
      anchors.left: prev.right
      margin-left: 3

    BestiaryStars
      id: stars5
      anchors.left: prev.right
      margin-left: 3

  UIWidget
    id: occurrenceContainer
    size: 60 10
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 6

    BestiaryOccurrence
      id: occurrence1

    BestiaryOccurrence
      id: occurrence2
      anchors.left: prev.right
      margin-left: 3

    BestiaryOccurrence
      id: occurrence3
      anchors.left: prev.right
      margin-left: 3

    BestiaryOccurrence
      id: occurrence4
      anchors.left: prev.right
      margin-left: 3

  Label
    id: typeContainer
    text: ?
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 6

  UIWidget
    id: charmAmountIcon
    image-source: /images/game/bestiary/charm
    anchors.top: prev.bottom
    anchors.left: prev.left
    margin-top: 7

  Label
    id: charmAmount
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 6
    width: 50

  VerticalSeparator
    id: verticalSeparator01
